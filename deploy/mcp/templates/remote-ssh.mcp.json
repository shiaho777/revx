{
  "mcpServers": {
    "revx": {
      "command": "ssh",
      "args": [
        "-i",
        "__SSH_IDENTITY_FILE__",
        "-o",
        "BatchMode=yes",
        "-o",
        "StrictHostKeyChecking=accept-new",
        "root@124.222.209.226",
        "/opt/revx/bin/revx-engine",
        "mcp",
        "serve",
        "--workspace",
        "/var/lib/revx/workspace"
      ]
    }
  }
}
